---
import { activities } from '../data/activities'
---

<section id="activities" class="py-24 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-2 fade-up">Activities</h2>
    <p class="text-gray-400 text-sm mb-16 fade-up">カンファレンス・コミュニティ活動</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {activities.map((activity, i) => (
        <div
          class="flex flex-col bg-white rounded-2xl border border-gray-100 shadow-sm p-5 fade-up"
          style={`transition-delay: ${i * 0.08}s`}
        >
          <!-- Logo / header -->
          {activity.logo
            ? <img src={activity.logo} alt={activity.conference} class="w-full h-16 object-contain mb-4" />
            : <span class="text-2xl font-bold text-gray-100 mb-4 block">{activity.period}</span>
          }

          <!-- Conference name + period -->
          <p class="text-sm font-semibold text-gray-800 leading-snug mb-1">{activity.conference}</p>
          <p class="text-xs text-gray-400 mb-2">{activity.period}</p>

          <!-- Description -->
          {activity.description && (
            <p class="text-xs text-gray-500 leading-relaxed mt-1 flex-1">{activity.description}</p>
          )}

          <!-- Links -->
          {activity.links && activity.links.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-3 pt-3 border-t border-gray-50">
              {activity.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-xs font-medium px-2.5 py-1 rounded-lg border border-gray-200 text-gray-600 hover:border-(--pink) hover:text-(--pink) transition-colors"
                >
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  {link.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
