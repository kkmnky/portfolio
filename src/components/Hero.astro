---
---

<section id="hero" class="min-h-screen flex flex-col bg-white relative">
  <div class="max-w-5xl mx-auto px-6 pt-52 pb-16 w-full">
    <div class="flex flex-col md:flex-row items-center gap-16">

      <!-- Text -->
      <div class="flex-1">
        <p class="text-sm font-medium tracking-widest uppercase mb-4 fade-up" style="color: var(--purple)">
          Site Reliability Engineer
        </p>
        <h1 class="text-6xl font-bold text-gray-900 mb-6 fade-up" style="transition-delay: 0.1s">
          かみけん
        </h1>
        <p class="text-xl text-gray-400 max-w-md leading-relaxed fade-up" style="transition-delay: 0.2s">
          しがないとあるSREのポートフォリオ
        </p>
      </div>

      <!-- Logo -->
      <div class="shrink-0 fade-up" style="transition-delay: 0.2s">
        <img
          src="/logo.jpg"
          alt="kmnky icon"
          class="w-64 h-64 object-contain"
        />
      </div>

    </div>
  </div>

  <!-- Scroll down indicator -->
  <div class="flex-1 flex items-end justify-center pb-16">
    <a
      href="#career"
      class="flex flex-col items-center gap-2 text-gray-400 hover:text-(--purple) transition-colors fade-up"
      style="transition-delay: 0.5s"
      aria-label="スクロールして見る"
    >
      <span class="text-sm tracking-widest uppercase">Scroll</span>
      <svg class="w-7 h-7 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>
</section>
