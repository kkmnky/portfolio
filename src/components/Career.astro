---
import { careerPhases } from '../data/career'

const phaseColors = [
  { dot: 'bg-slate-400', badge: 'bg-slate-50 text-slate-600', tag: 'bg-slate-100 text-slate-700' },
  { dot: 'bg-sky-400',   badge: 'bg-sky-50 text-sky-600',     tag: 'bg-sky-100 text-sky-700' },
  { dot: 'bg-teal-500',  badge: 'bg-teal-50 text-teal-700',   tag: 'bg-teal-100 text-teal-700' },
]
---

<section id="career" class="py-24 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-2 fade-up">Career</h2>
    <p class="text-gray-400 text-sm mb-16 fade-up">経歴・スキル・資格</p>

    <div class="relative">
      <!-- Timeline vertical line -->
      <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200 ml-[7px]"></div>

      <div class="space-y-14">
        {careerPhases.map((phase, i) => {
          const color = phaseColors[i] ?? phaseColors[0]
          return (
            <div class="relative pl-10 fade-up" style={`transition-delay: ${i * 0.15}s`}>
              <!-- Dot -->
              <div class={`absolute left-0 top-1.5 w-4 h-4 rounded-full ${color.dot} ring-4 ring-slate-50`}></div>

              <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
                <!-- Header -->
                <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                  <div>
                    <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full mb-2 ${color.badge}`}>
                      {phase.period}
                    </span>
                    <h3 class="text-xl font-bold text-gray-900">{phase.role}</h3>
                  </div>
                </div>

                <p class="text-gray-500 text-sm leading-relaxed mb-5">{phase.description}</p>

                <!-- Strengths -->
                <div class="mb-4">
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">強み</p>
                  <div class="flex flex-wrap gap-2">
                    {phase.strengths.map((s) => (
                      <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${color.tag}`}>{s}</span>
                    ))}
                  </div>
                </div>

                <!-- Skills -->
                <div class="mb-4">
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">スキル</p>
                  <div class="flex flex-wrap gap-2">
                    {phase.skills.map((s) => (
                      <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 text-gray-600">{s}</span>
                    ))}
                  </div>
                </div>

                <!-- Certifications -->
                {phase.certifications.length > 0 && (
                  <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">資格</p>
                    <div class="flex flex-wrap gap-2">
                      {phase.certifications.map((c) => (
                        <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-amber-50 text-amber-700 border border-amber-100">
                          {c}
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>
