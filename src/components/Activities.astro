---
import { activities } from '../data/activities'
---

<section id="activities" class="py-24 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-2 fade-up">Activities</h2>
    <p class="text-gray-400 text-sm mb-16 fade-up">カンファレンス・コミュニティ活動</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {activities.map((activity, i) => (
        <div
          class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 fade-up"
          style={`transition-delay: ${i * 0.08}s`}
        >
          <div class="flex items-start justify-between mb-3">
            <span class="text-2xl font-bold text-gray-100">{activity.year}</span>
            <span
              class="text-xs font-medium px-2.5 py-1 rounded-full"
              style="background-color: var(--pink-light); color: var(--pink-dark)"
            >
              {activity.role}
            </span>
          </div>
          <p class="text-sm font-semibold text-gray-800 leading-snug">{activity.conference}</p>
        </div>
      ))}
    </div>
  </div>
</section>
