---
const blogUrl = 'https://kmnky.dev/'

let ogImage = ''
let ogDescription = ''

try {
  const res = await fetch(blogUrl)
  const html = await res.text()
  ogImage       = html.match(/<meta[^>]+property="og:image"[^>]+content="([^"]+)"/)?.[1] ?? ''
  ogDescription = html.match(/<meta[^>]+property="og:description"[^>]+content="([^"]+)"/)?.[1] ?? ''
} catch {}
---

<section id="blog" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-2 fade-up">Blog</h2>
    <p class="text-gray-400 text-sm mb-16 fade-up">技術ブログ</p>

    <a
      href={blogUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex flex-col sm:flex-row items-center gap-8 bg-white border border-gray-100 shadow-sm hover:shadow-md rounded-2xl p-8 transition-all duration-300 fade-up"
      onmouseover="this.style.borderColor='var(--purple)'"
      onmouseout="this.style.borderColor=''"
    >
      <div class="flex items-center justify-between gap-6 flex-1">
        <div>
          <p class="text-xs font-medium mb-1 tracking-wide" style="color: var(--purple)">BLOG</p>
          <h3 class="text-xl font-bold text-gray-900 group-hover:text-(--purple) transition-colors mb-2">
            kmnky.dev
          </h3>
          {ogDescription && (
            <p class="text-sm text-gray-400 leading-relaxed">{ogDescription}</p>
          )}
        </div>
      </div>
      {ogImage && (
        <div class="shrink-0">
          <img src={ogImage} alt="kmnky.dev" class="w-64 h-36 object-cover rounded-xl" />
        </div>
      )}
    </a>
  </div>
</section>
