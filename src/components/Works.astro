---
import { works, phaseStyle } from '../data/works'

const categoryStyle: Record<string, string> = {
  Education:     'background-color: var(--purple-light); color: var(--purple-dark)',
  Observability: 'background-color: var(--teal-light);   color: var(--teal-dark)',
  Learning:      'background-color: var(--pink-light);   color: var(--pink-dark)',
  Web:           'background-color: var(--purple-light); color: var(--purple-dark)',
}

const hoverColor: Record<string, string> = {
  infra: "var(--purple)",
  rnd:   "var(--teal)",
  sre:   "var(--pink)",
}
---

<section id="works" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-2 fade-up">Works</h2>
    <p class="text-gray-400 text-sm mb-16 fade-up">作成物 ※業務は公開できないものがほとんどのためプライベートの活動が中心</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {works.map((work, i) => (
        <div
          class="flex flex-col bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 p-6 fade-up"
          style={`transition-delay: ${i * 0.08}s`}
        >
          <!-- Header -->
          <div class="mb-3">
            <span class="text-xs font-medium px-2 py-0.5 rounded-full" style={work.phase ? phaseStyle[work.phase].style : categoryStyle[work.category]}>
              {work.category}
            </span>
          </div>

          <!-- Title & description -->
          <h3 class="text-base font-bold text-gray-900 mb-2">
            {work.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1 mb-4">{work.description}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5 mb-4">
            {work.tags.map((tag) => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">{tag}</span>
            ))}
          </div>

          <!-- Links -->
          <div class="flex flex-wrap items-center gap-2 mt-auto pt-2 border-t border-gray-50">
            {work.github && (
              <a
                href={work.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-lg bg-gray-900 text-white hover:bg-gray-700 transition-colors"
                onclick="event.stopPropagation()"
              >
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                GitHub
              </a>
            )}
            {work.links?.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-lg border border-gray-200 text-gray-600 hover:border-(--teal) hover:text-(--teal) transition-colors"
                onclick="event.stopPropagation()"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
