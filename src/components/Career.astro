---
import { careerPhases } from '../data/career'

const phaseStyles = [
  {
    dot:    'background-color: var(--purple)',
    ring:   'ring-slate-50',
    badge:  'background-color: var(--purple-light); color: var(--purple-dark)',
    tag:    'background-color: var(--purple-light); color: var(--purple-dark)',
    skill:  'bg-gray-100 text-gray-600',
    cert:   'background-color: #FFF8E1; color: #F57F17; border: 1px solid #FFE082',
  },
  {
    dot:    'background-color: var(--teal)',
    ring:   'ring-slate-50',
    badge:  'background-color: var(--teal-light); color: var(--teal-dark)',
    tag:    'background-color: var(--teal-light); color: var(--teal-dark)',
    skill:  'bg-gray-100 text-gray-600',
    cert:   'background-color: #FFF8E1; color: #F57F17; border: 1px solid #FFE082',
  },
  {
    dot:    'background-color: var(--pink)',
    ring:   'ring-slate-50',
    badge:  'background-color: var(--pink-light); color: var(--pink-dark)',
    tag:    'background-color: var(--pink-light); color: var(--pink-dark)',
    skill:  'bg-gray-100 text-gray-600',
    cert:   'background-color: #FFF8E1; color: #F57F17; border: 1px solid #FFE082',
  },
]
---

<section id="career" class="py-24 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-2 fade-up">Career</h2>
    <p class="text-gray-400 text-sm mb-16 fade-up">経歴・スキル・資格</p>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200 ml-[7px]"></div>

      <div class="space-y-14">
        {careerPhases.map((phase, i) => {
          const s = phaseStyles[i] ?? phaseStyles[0]
          return (
            <div class="relative pl-10 fade-up" style={`transition-delay: ${i * 0.15}s`}>
              <!-- Dot -->
              <div
                class={`absolute left-0 top-1.5 w-4 h-4 rounded-full ring-4 ${s.ring}`}
                style={s.dot}
              ></div>

              <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
                <!-- Header -->
                <div class="mb-4">
                  <span
                    class="inline-block text-xs font-medium px-2.5 py-1 rounded-full mb-2"
                    style={s.badge}
                  >
                    {phase.period}
                  </span>
                  <h3 class="text-xl font-bold text-gray-900">{phase.role}</h3>
                </div>

                <p class="text-gray-500 text-sm leading-relaxed mb-5">{phase.description}</p>

                <!-- Strengths -->
                <div class="mb-4">
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">強み</p>
                  <div class="flex flex-wrap gap-2">
                    {phase.strengths.map((str) => (
                      <span class="text-xs font-medium px-2.5 py-1 rounded-full" style={s.tag}>{str}</span>
                    ))}
                  </div>
                </div>

                <!-- Skills -->
                <div class="mb-4">
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">スキル</p>
                  <div class="flex flex-wrap gap-2">
                    {phase.skills.map((sk) => (
                      <span class={`text-xs px-2.5 py-1 rounded-full ${s.skill}`}>{sk}</span>
                    ))}
                  </div>
                </div>

                <!-- Certifications -->
                {phase.certifications.length > 0 && (
                  <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">資格</p>
                    <div class="flex flex-wrap gap-2">
                      {phase.certifications.map((c) => (
                        <span class="text-xs font-medium px-2.5 py-1 rounded-full" style={s.cert}>{c}</span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>
